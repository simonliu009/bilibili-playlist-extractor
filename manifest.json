{
  "manifest_version": 3,
  "name": "B站导出与双击复制",
  "version": "1.4",
  "description": "导出B站视频/合辑信息为Markdown格式，并支持全站双击中键复制Markdown链接",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.bilibili.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
